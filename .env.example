# /home/ubuntu/aguia/.env — Aguia fleet shared secrets
# Copy to .env and fill in real values. NEVER commit real secrets.

# --- Existing (already populated) ---
INTERVALS_API_KEY=xxx
NEWSLETTER_ADMIN_SECRET=xxx
RESEND_API_KEY=xxx

# --- FALCAO video pipeline (Track B) ---
# Get at https://fal.ai/dashboard/keys (format: fal_live_xxx or key_id:key_secret)
FAL_KEY=fal_xxx

# Monthly spend cap across all video models. Default 50.0 USD.
VIDEO_BUDGET_USD=50

# --- FALCAO X (Twitter) video posting ---
# https://developer.twitter.com — "Keys and tokens" tab, Write scope required.
X_API_KEY=xxx
X_API_SECRET=xxx
X_ACCESS_TOKEN=xxx
X_ACCESS_SECRET=xxx

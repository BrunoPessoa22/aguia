# Claude Code OAuth token (free via `claude auth login`)
CLAUDE_CODE_OAUTH_TOKEN=your_oauth_token_here

# Telegram bot tokens (create via @BotFather)
TELEGRAM_BOT_TOKEN=your_default_bot_token
AGUIA_BOT_TOKEN=your_interactive_bot_token

# Telegram chat IDs for routing
OWNER_DM=your_telegram_chat_id
TEAM_GROUP=your_team_group_chat_id

# WAsenderAPI (optional — WhatsApp integration, ~$6/mo)
WASENDER_SESSION_KEY=your_wasender_api_key
WASENDER_WEBHOOK_SECRET=your_webhook_secret

# LinkedIn (optional — DM automation)
LI_EMAIL=your_linkedin_email
LI_PASS=your_linkedin_password
